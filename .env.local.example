# 멜라누아 스튜디오 — 환경변수 템플릿
# 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요. (.env.local 은 절대 커밋 금지)
#   cp .env.local.example .env.local
# 값 위치: Supabase 대시보드 → Project Settings → API

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY        # ⚠️ 로컬 전용 · RLS 우회(전체 권한) · 절대 공개 금지
SUPABASE_ANON_KEY=YOUR-ANON-KEY                   # 공개키(RLS 제한) — 웹 콘솔용
SUPABASE_DB_PASSWORD=YOUR-DB-PASSWORD             # apply-schema.mjs 가 사용

# (선택) 자사몰 인사이트 자동 발행 — melanoir.co.kr 레포의 insights 디렉터리 경로.
#   설정하면 데일리 발행 시 GEO/SEO 정적 아티클 생성 + git commit&push(자동 배포). 소유자 쓰기 권한 필요.
#   예) MELANOIR_SITE_REPO=/Users/me/melanoir-recruitment/web/site/insights
MELANOIR_SITE_REPO=

# ANTHROPIC_API_KEY 는 필요 없습니다 — 카피는 Claude Code 구독 에이전트가 작성합니다.
